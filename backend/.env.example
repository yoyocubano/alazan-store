# ── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
ADMIN_KEY=XXXXXXXXXXXXXXXX

# ── POD PROVIDER ROUTING ────────────────────────────────────────────────────
# Options per country — change to override defaults
# BR_PROVIDER: dimona | reservaink
# US_PROVIDER: printful | gelato | printify
# CA_PROVIDER: printful | gelato
BR_PROVIDER=dimona
US_PROVIDER=printful
CA_PROVIDER=printful

# ── STRIPE (US / CA / MX — tarjetas internacionales) ────────────────────────
# Dashboard: https://dashboard.stripe.com → Developers → API Keys
# Webhook URL: https://tu-api.com/api/webhooks/stripe
# Webhook events: checkout.session.completed, payment_intent.payment_failed
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── MERCADO PAGO (AR / BR / MX) ─────────────────────────────────────────────
# Crear apps en: https://www.mercadopago.com.ar/developers/panel (por país)
# Webhook URL: https://tu-api.com/api/webhooks/mercadopago | Evento: payment
# Argentina
MP_AR_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
MP_AR_PUBLIC_KEY=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
# Brazil
MP_BR_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
MP_BR_PUBLIC_KEY=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
# Mexico
MP_MX_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
MP_MX_PUBLIC_KEY=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX

# ── DIMONA POD (AR / BR / MX / US) ─────────────────────────────────────────
# Endpoint: https://api.dimonatee.com/api/v2021
# Auth: Bearer Token (solicitar acceso en https://dimonatee.com)
# Sandbox: enviar "sample": true en el payload (mismo endpoint)
DIMONA_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── PRINTFUL POD (US / CA / MX / BR) ────────────────────────────────────────
# Dashboard: https://developers.printful.com
# Auth: Scoped Private Token (configurar permisos en Developer Portal)
# Sandbox: cancelar manualmente en dashboard antes de que entre a producción
PRINTFUL_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PRINTFUL_STORE_ID=XXXXXXXX
# IDs de productos base (verificar en GET /products/{id}/variants)
PRINTFUL_TSHIRT_ID=71
PRINTFUL_SWEATSHIRT_ID=378
PRINTFUL_HOODIE_ID=146
PRINTFUL_KIDS_TSHIRT_ID=200

# ── GELATO POD (US / CA / MX / BR vía red global) ──────────────────────────
# Dashboard: https://dashboard.gelato.com
# Auth: X-API-KEY header (generar en Gelato Connect → API Keys)
# Sandbox: REAL sandbox disponible — registrar "Sandbox Customer" en portal
# ⚠️ Restricción: CA/MX/BR = solo frente+espalda (sin mangas ni etiqueta cuello)
GELATO_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── PRINTIFY POD (US / CA / MX / BR via marketplace de proveedores) ─────────
# Dashboard: https://printify.com/app/settings/api
# Auth: Bearer Token + OBLIGATORIO User-Agent header
# Sandbox: no disponible — cancelar manualmente en dashboard
# ⚠️ Variación de calidad posible entre proveedores — pedir muestras físicas
PRINTIFY_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PRINTIFY_SHOP_ID=XXXXXXXX
PRINTIFY_USER_AGENT=NodeJS / AlazanStore

# ── RESERVA INK / LIVE INK (Brasil exclusivo) ───────────────────────────────
# Integración INVERSA: Live Ink se conecta a TU WooCommerce, no al revés.
# Setup: 1) Crear cuenta en live.ink
#        2) Ingresar URL de tu WooCommerce
#        3) Autorizar OAuth en tu WP Admin (Application Passwords)
# Requisitos: Permalinks = "Post name" | Wordfence: permitir Application Passwords
# Plan Essencial: R$399/mes — https://live.ink/pricing
# Las credenciales WC son para leer tracking de vuelta desde WooCommerce:
WOOCOMMERCE_URL=https://tutienda.com
WC_CONSUMER_KEY=ck_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WC_CONSUMER_SECRET=cs_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESERVAINK_NECK_LABEL_URL=https://tutienda.com/assets/neck-label.png

# ── EMAIL (SMTP — confirmaciones de orden + tracking) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=orders@alazanstore.shop
SMTP_PASS=XXXXXXXXXXXXXXXX

# ── TIPOS DE CAMBIO (actualizar o conectar a API de rates) ──────────────────
# Referencia: https://api.exchangerate-api.com (1500 req/mes gratis)
# 1 USD = X moneda local
RATE_ARS=950
RATE_BRL=5.05
RATE_MXN=17.2
RATE_CAD=1.36
